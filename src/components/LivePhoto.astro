---
/**
 * LivePhoto.astro - Using live-photo-component npm package
 * @see https://www.npmjs.com/package/live-photo-component
 */
interface Props {
  photo: string;
  video: string;
  width?: number | string;
  muted?: boolean;
  loop?: boolean;
  autoplay?: boolean;
  radius?: number;
}

const {
  photo,
  video,
  width = 600,
  muted = true,
  loop = false,
  autoplay = false,
  radius = 8
} = Astro.props;
---

<!-- Import Web Component -->
<script is:inline src="/live-photo/live-photo.umd.js"></script>
<link is:inline rel="stylesheet" href="/live-photo/styles.css">

<live-photo 
  photo={photo}
  video={video}
  width={typeof width === 'number' ? `${width}px` : width}
  muted={muted}
  loop={loop}
  autoplay={autoplay}
  radius={radius.toString()}
></live-photo>

<style is:inline>
  live-photo {
    display: block;
    margin: 1.5em auto;
  }
</style>
