---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { alternatePostHref, postLang, postSlug } from "../../../lib/posts";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const enPosts = posts.filter((post) => postLang(post) === "en" && !post.data.draft);

  return enPosts.map((post) => ({
    params: { slug: postSlug(post.id) },
    props: { post, allPosts: posts }
  }));
}

const { post, allPosts } = Astro.props;
const { Content } = await render(post);
const alternatePath = alternatePostHref(post, allPosts, "zh");

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    year: "numeric",
    month: "long",
    day: "numeric"
  }).format(date);
---

<BaseLayout lang="en" title={`${post.data.title} | Openfilm`} description={post.data.description} alternatePath={alternatePath}>
  <section class="content-page">
    <aside class="content-rail">
      <p class="kicker">Article</p>
      <p class="meta">{formatDate(post.data.pubDate)}</p>
      {post.data.tags.length > 0 && (
        <div class="tag-list">
          {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      )}
    </aside>

    <article>
      <p class="meta">Openfilm / Film, tools, darkroom, and visual culture</p>
      <h1>{post.data.title}</h1>
      <p class="lede">{post.data.description}</p>
      <Content />
      <div class="article-footer">
        <a class="button" href="/en/">Back to posts</a>
        <a class="button" href={alternatePath}>Read another language</a>
      </div>
    </article>
  </section>
</BaseLayout>
