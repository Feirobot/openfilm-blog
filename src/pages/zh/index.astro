---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const lang = "zh";
const posts = (await getCollection("posts"))
  .filter((post) => !post.data.draft && post.data.lang === lang)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("zh-CN", {
    year: "numeric",
    month: "long",
    day: "numeric"
  }).format(date);

const postSlug = (id: string) => id.replace(/\.mdx?$/, "");
---

<BaseLayout lang={lang}>
  <section>
    <h1>Openfilm</h1>
    <p class="lede">
      关于胶片、媒体、工具以及值得细细品味的事物的笔记、随笔与实验。
    </p>
  </section>

  <section class="post-list" aria-label="最新文章">
    {
      posts.map((post) => (
        <a class="post-card" href={`/zh/posts/${postSlug(post.id)}/`}>
          <span class="meta">{formatDate(post.data.pubDate)}</span>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
          {post.data.tags.length > 0 && (
            <div class="tags">
              {post.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))
    }
  </section>
</BaseLayout>
