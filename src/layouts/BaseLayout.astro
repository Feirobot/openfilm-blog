---
const {
  title = "Openfilm",
  description = "Notes, essays, and experiments from Openfilm.",
  lang = "zh"
} = Astro.props;

// Translations
const translations = {
  zh: {
    brand: "Openfilm",
    posts: "文章",
    about: "关于",
    rss: "RSS",
    footer: "Openfilm.cc",
    langSwitch: "English"
  },
  en: {
    brand: "Openfilm",
    posts: "Posts",
    about: "About",
    rss: "RSS",
    footer: "Openfilm.cc",
    langSwitch: "中文"
  }
};

const t = translations[lang] || translations.zh;
const htmlLang = lang === "zh" ? "zh-CN" : "en";
const otherLang = lang === "zh" ? "en" : "zh";
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Openfilm RSS" href="/rss.xml" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4428777285258225"
     crossorigin="anonymous"></script>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={`/${lang}/`}>{t.brand}</a>
      <nav aria-label="Primary navigation">
        <a href={`/${lang}/`}>{t.posts}</a>
        <a href={`/${lang}/about/`}>{t.about}</a>
        <a href="/rss.xml">{t.rss}</a>
        <a href={`/${otherLang}/`} class="lang-switch-btn" title={t.langSwitch}>
          {t.langSwitch}
        </a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>{t.footer}</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f7f4ed;
    --surface: #fffdf8;
    --text: #161817;
    --muted: #646860;
    --line: #ded7c9;
    --accent: #0f766e;
    --accent-dark: #134e4a;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
    line-height: 1.65;
  }

  a {
    color: inherit;
  }

  .site-header,
  main,
  footer {
    width: min(100% - 32px, 840px);
    margin-inline: auto;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 28px 0 18px;
    border-bottom: 1px solid var(--line);
  }

  .brand {
    color: var(--text);
    font-size: 1.15rem;
    font-weight: 750;
    text-decoration: none;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 18px;
    color: var(--muted);
    font-size: 0.95rem;
  }

  nav a {
    text-decoration: none;
  }

  nav a:hover {
    color: var(--accent-dark);
  }

  .lang-switch-btn {
    padding: 6px 12px;
    border-radius: 6px;
    border: 1px solid var(--line);
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .lang-switch-btn:hover {
    background: var(--surface);
    border-color: var(--accent);
    color: var(--accent-dark);
  }

  main {
    padding: 56px 0 72px;
  }

  footer {
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.9rem;
    padding: 22px 0 36px;
  }

  h1,
  h2,
  h3 {
    line-height: 1.12;
  }

  h1 {
    margin: 0 0 18px;
    font-size: clamp(2.25rem, 8vw, 4.75rem);
    max-width: 760px;
  }

  h2 {
    margin: 42px 0 12px;
    font-size: 1.65rem;
  }

  p {
    margin: 0 0 18px;
  }

  .lede {
    max-width: 640px;
    color: var(--muted);
    font-size: 1.18rem;
  }

  .post-list {
    display: grid;
    gap: 20px;
    margin-top: 42px;
  }

  .post-card {
    display: block;
    padding: 22px 0;
    border-top: 1px solid var(--line);
    text-decoration: none;
  }

  .post-card h2 {
    margin: 0 0 8px;
    font-size: 1.45rem;
  }

  .post-card p {
    color: var(--muted);
  }

  .meta {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  .tag {
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--accent-dark);
    font-size: 0.8rem;
    line-height: 1;
    padding: 7px 10px;
  }

  article {
    max-width: 720px;
  }

  article :is(p, li) {
    font-size: 1.05rem;
  }

  article a {
    color: var(--accent-dark);
  }

  article img {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 1.5rem auto;
    border-radius: 8px;
    border: 1px solid var(--line);
  }

  article h1, article h2, article h3 {
    margin-top: 2rem;
  }

  @media (max-width: 620px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
      gap: 12px;
    }

    main {
      padding-top: 38px;
    }
  }
</style>
