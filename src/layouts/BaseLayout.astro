---
const {
  title = "Openfilm",
  description = "Film, tools, darkroom, and visual culture notes from Openfilm.",
  lang = "zh",
  alternatePath
} = Astro.props;

const translations = {
  zh: {
    posts: "文章",
    columns: "栏目",
    about: "关于",
    rss: "RSS",
    issue: "胶片摄影 / 影像文化 / 暗房笔记",
    footerLeft: "Openfilm.cc",
    footerRight: "Film, tools, darkroom, culture.",
    langLabel: "EN"
  },
  en: {
    posts: "Posts",
    columns: "Columns",
    about: "About",
    rss: "RSS",
    issue: "Analog photography / media culture / field notes",
    footerLeft: "Openfilm.cc",
    footerRight: "Film, tools, darkroom, culture.",
    langLabel: "中文"
  }
};

const t = translations[lang] || translations.zh;
const htmlLang = lang === "zh" ? "zh-CN" : "en";
const otherLang = lang === "zh" ? "en" : "zh";
const switchPath = alternatePath || `/${otherLang}/`;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Openfilm RSS" href="/rss.xml" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4428777285258225" crossorigin="anonymous"></script>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={`/${lang}/`}>Openfilm</a>
      <div class="issue">{t.issue}</div>
      <nav aria-label="Primary navigation">
        <a href={`/${lang}/`}>{t.posts}</a>
        <a href={`/${lang}/#columns`}>{t.columns}</a>
        <a href={`/${lang}/about/`}>{t.about}</a>
        <a href="/rss.xml">{t.rss}</a>
        <a class="button lang-switch-btn" href={switchPath} hreflang={otherLang}>{t.langLabel}</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <span>{t.footerLeft}</span>
      <span>{t.footerRight}</span>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #111111;
    --graphite: #242424;
    --muted: #6d6a64;
    --paper: #f2efe8;
    --panel: #fbfaf6;
    --line: #d8d0c3;
    --safelight: #b64026;
    --cyan: #126f78;
    --sage: #c9d7bf;
    --shadow: 0 22px 55px rgba(17, 17, 17, 0.16);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  * {
    min-width: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: var(--paper);
    color: var(--ink);
    line-height: 1.62;
    overflow-x: hidden;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input {
    font: inherit;
  }

  .site-header,
  main,
  footer {
    width: calc(100% - 32px);
    max-width: 1180px;
    margin-inline: auto;
  }

  .site-header {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 24px;
    padding: 26px 0 18px;
    border-bottom: 2px solid var(--ink);
  }

  .brand {
    color: var(--ink);
    font-size: 1.25rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .issue {
    justify-self: center;
    color: var(--muted);
    font-size: 0.86rem;
  }

  nav {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 16px;
    color: var(--graphite);
    font-size: 0.95rem;
  }

  nav a:hover {
    color: var(--safelight);
  }

  main {
    padding: 30px 0 74px;
  }

  footer {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    border-top: 2px solid var(--ink);
    color: var(--muted);
    font-size: 0.9rem;
    padding: 22px 0 36px;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    line-height: 1.04;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  p {
    margin: 0 0 18px;
    overflow-wrap: anywhere;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 8px 14px;
    border: 1px solid var(--ink);
    border-radius: 4px;
    background: transparent;
    color: var(--ink);
    cursor: pointer;
    font-weight: 750;
    text-decoration: none;
  }

  .button.primary {
    background: var(--ink);
    color: var(--panel);
  }

  .button:hover {
    background: var(--sage);
    color: var(--ink);
  }

  .kicker {
    margin: 0 0 12px;
    color: var(--safelight);
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .meta {
    color: var(--muted);
    font-size: 0.88rem;
  }

  .lede {
    max-width: 720px;
    color: var(--graphite);
    font-size: 1.18rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }

  .tag {
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--cyan);
    background: var(--panel);
    font-size: 0.8rem;
    font-weight: 750;
    line-height: 1;
    padding: 7px 10px;
  }

  .page-shell {
    border-bottom: 2px solid var(--ink);
    padding-bottom: 28px;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(320px, 0.82fr);
    gap: 26px;
    min-height: 620px;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-width: 0;
    min-height: 620px;
    padding: 24px 26px;
    background: var(--panel);
    border: 1px solid var(--line);
  }

  .hero-copy h1 {
    max-width: 780px;
    font-size: 6.1rem;
    font-weight: 930;
  }

  .hero-copy .lede {
    margin-top: 22px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .hero-aside {
    display: grid;
    grid-template-rows: 1fr auto;
    min-width: 0;
    background: var(--ink);
    color: var(--panel);
    box-shadow: var(--shadow);
  }

  .hero-image {
    width: 100%;
    height: 100%;
    min-height: 385px;
    object-fit: cover;
    display: block;
    filter: contrast(1.04) saturate(0.86);
  }

  .featured {
    min-width: 0;
    padding: 24px;
    border-top: 8px solid var(--safelight);
  }

  .featured .meta {
    color: #d7d0c7;
  }

  .featured h2 {
    margin: 10px 0;
    font-size: 2rem;
    overflow-wrap: anywhere;
  }

  .featured p {
    margin: 0;
    color: #e6dfd6;
    overflow-wrap: anywhere;
  }

  .section-row {
    display: grid;
    grid-template-columns: 290px minmax(0, 1fr);
    gap: 28px;
    padding: 32px 0;
    border-bottom: 1px solid var(--line);
  }

  .section-label {
    position: sticky;
    top: 18px;
    min-width: 0;
    align-self: start;
  }

  .section-label h2 {
    font-size: 2.4rem;
  }

  .section-label p {
    margin: 14px 0 0;
    color: var(--muted);
  }

  .post-list {
    display: grid;
    gap: 12px;
  }

  .pagination {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 22px;
  }

  .page-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .page-link {
    min-width: 40px;
    min-height: 40px;
    padding: 8px 12px;
    border: 1px solid var(--line);
    border-radius: 4px;
    background: var(--panel);
    color: var(--ink);
    font-weight: 750;
    text-align: center;
  }

  .page-link[aria-current="page"] {
    border-color: var(--ink);
    background: var(--ink);
    color: var(--panel);
  }

  .post-card {
    display: grid;
    grid-template-columns: 116px minmax(0, 1fr) auto;
    gap: 20px;
    align-items: center;
    min-height: 132px;
    padding: 18px;
    border: 1px solid var(--line);
    background: var(--panel);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .post-card:hover {
    transform: translateY(-2px);
    border-color: var(--ink);
    box-shadow: 0 16px 32px rgba(17, 17, 17, 0.08);
  }

  .post-number {
    color: var(--safelight);
    font-size: 3rem;
    font-weight: 920;
    line-height: 1;
  }

  .post-card h2,
  .post-card h3 {
    margin: 5px 0 7px;
    font-size: 1.55rem;
    line-height: 1.15;
    overflow-wrap: anywhere;
  }

  .post-card p {
    max-width: 660px;
    margin: 0;
    color: var(--muted);
    font-size: 0.98rem;
  }

  .category-mark {
    justify-self: end;
    min-width: 92px;
    border-left: 3px solid var(--cyan);
    color: var(--cyan);
    font-size: 0.82rem;
    font-weight: 800;
    padding-left: 10px;
    text-transform: uppercase;
    overflow-wrap: anywhere;
  }

  .topics {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .topic {
    min-height: 180px;
    padding: 18px;
    border: 1px solid var(--line);
    background: var(--panel);
  }

  .topic strong {
    display: block;
    margin-bottom: 42px;
    color: var(--safelight);
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .topic h3 {
    font-size: 1.4rem;
  }

  .topic p {
    margin: 10px 0 0;
    color: var(--muted);
    font-size: 0.94rem;
  }

  .content-page {
    display: grid;
    grid-template-columns: 280px minmax(0, 760px);
    gap: 48px;
    align-items: start;
  }

  .content-rail {
    position: sticky;
    top: 18px;
    padding-top: 8px;
    border-top: 8px solid var(--safelight);
  }

  .content-rail p {
    color: var(--muted);
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  article {
    min-width: 0;
    padding: 28px;
    border: 1px solid var(--line);
    background: var(--panel);
  }

  article h1 {
    margin: 8px 0 16px;
    font-size: 4rem;
    font-weight: 930;
    overflow-wrap: anywhere;
  }

  article h2 {
    margin: 2.2rem 0 0.85rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--line);
    font-size: 1.7rem;
  }

  article h3 {
    margin: 1.6rem 0 0.7rem;
    font-size: 1.28rem;
  }

  article :is(p, li) {
    color: var(--graphite);
    font-size: 1.05rem;
  }

  article a {
    color: var(--cyan);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  article img {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 1.6rem auto;
    border: 10px solid var(--ink);
  }

  article code {
    border: 1px solid var(--line);
    border-radius: 4px;
    background: #ede7dd;
    padding: 0.12em 0.34em;
  }

  .article-footer {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 14px;
    margin-top: 34px;
    padding-top: 20px;
    border-top: 1px solid var(--line);
  }

  .newsletter {
    display: grid;
    grid-template-columns: 1fr minmax(280px, 420px);
    gap: 28px;
    align-items: end;
    margin-top: 34px;
    padding: 26px;
    background: var(--ink);
    color: var(--panel);
  }

  .newsletter > * {
    min-width: 0;
  }

  .newsletter h2 {
    font-size: 3rem;
  }

  .newsletter p {
    max-width: 600px;
    margin: 12px 0 0;
    color: #d7d0c7;
  }

  .newsletter-form {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 10px;
  }

  .newsletter input {
    min-width: 0;
    min-height: 42px;
    border: 1px solid #6d665d;
    border-radius: 4px;
    background: #1f1f1f;
    color: var(--panel);
    padding: 9px 12px;
  }

  .newsletter .button {
    border-color: var(--panel);
    color: var(--panel);
  }

  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 26px;
  }

  .about-card {
    padding: 26px;
    border: 1px solid var(--line);
    background: var(--panel);
  }

  .about-card h1 {
    margin-bottom: 18px;
    font-size: 5rem;
    font-weight: 930;
  }

  .about-card p {
    color: var(--graphite);
    font-size: 1.08rem;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .about-aside {
    padding: 24px;
    background: var(--ink);
    color: var(--panel);
  }

  .about-aside p {
    color: #d7d0c7;
    overflow-wrap: anywhere;
  }

  @media (max-width: 980px) {
    .site-header {
      grid-template-columns: 1fr;
    }

    .issue,
    nav {
      justify-self: start;
      justify-content: flex-start;
    }

    .hero,
    .section-row,
    .content-page,
    .newsletter,
    .about-grid {
      grid-template-columns: 1fr;
    }

    .hero,
    .hero-copy {
      min-height: auto;
    }

    .hero-copy h1 {
      font-size: 4.6rem;
    }

    .section-label,
    .content-rail {
      position: static;
    }

    .topics {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .site-header {
      gap: 12px;
    }

    nav {
      flex-wrap: wrap;
    }

    main {
      padding-top: 18px;
    }

    .hero-copy,
    article,
    .about-card {
      padding: 20px;
    }

    .hero-copy h1 {
      font-size: 2.45rem;
      overflow-wrap: anywhere;
      word-break: break-all;
    }

    .lede {
      font-size: 1.05rem;
    }

    .featured h2,
    .section-label h2,
    .about-card h1 {
      font-size: 1.72rem;
      overflow-wrap: anywhere;
      word-break: break-all;
    }

    .featured p,
    .about-card p,
    .about-aside p,
    article :is(p, li),
    article h1,
    .post-card p,
    .post-card h2,
    .post-card h3 {
      overflow-wrap: anywhere;
      word-break: break-all;
    }

    .post-card {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .category-mark {
      justify-self: start;
    }

    .topics,
    .newsletter-form {
      grid-template-columns: 1fr;
    }

    .newsletter h2 {
      font-size: 2.2rem;
    }

    article h1 {
      font-size: 2rem;
    }

    article img {
      border-width: 6px;
    }
  }
</style>
